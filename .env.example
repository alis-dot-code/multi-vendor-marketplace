# PostgreSQL
POSTGRES_PASSWORD=MarketNest@123

# JWT Settings
JwtSettings__Key=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
JwtSettings__Issuer=MarketNest
JwtSettings__Audience=MarketNestUsers
JwtSettings__AccessTokenExpirationMinutes=15
JwtSettings__RefreshTokenExpirationDays=7

# Stripe
StripeSettings__SecretKey=sk_test_your_stripe_secret_key
StripeSettings__WebhookSecret=whsec_your_webhook_secret
StripeSettings__PlatformFeePercent=10

# Cloudinary
CloudinarySettings__CloudName=your_cloud_name
CloudinarySettings__ApiKey=your_api_key
CloudinarySettings__ApiSecret=your_api_secret

# SendGrid
SendGridSettings__ApiKey=SG.your_sendgrid_api_key
SendGridSettings__FromEmail=noreply@marketnest.com
SendGridSettings__FromName=MarketNest

# CORS
CorsOrigins__0=http://localhost:5173
CorsOrigins__1=http://localhost:3000

# Frontend (for .env file)
# VITE_API_URL=http://localhost:5000
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# VITE_GOOGLE_CLIENT_ID=your_google_client_id
